<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram id="sysarch" name="System Architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Lights, Fans, Discord — System Architecture" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="480" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- ================= COLUMN 1: SIMULATED DEVICE LAYER ================= -->
        <mxCell id="col1header" value="1. Simulated Device Layer" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="260" height="30" as="geometry" />
        </mxCell>

        <mxCell id="simulator" value="Device Simulator&#10;(asyncio background task)&#10;&#10;• 15 devices (2 fans + 3 lights x 3 rooms)&#10;• Occupancy-based on/off model&#10;• Simulated clock (adjustable speed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="140" width="260" height="130" as="geometry" />
        </mxCell>

        <mxCell id="devicestate" value="In-Memory Device State&#10;(single source of truth)&#10;&#10;status | watts | room&#10;last_changed | on_since" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;elbow=vertical;startArrow=none;" edge="1" parent="1" source="simulator" target="devicestate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1label" value="writes state&#10;every tick" style="edgeLabel;html=1;align=center;fontSize=10;fontColor=#666666;" vertex="1" connectable="0" parent="e1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ================= COLUMN 2: BACKEND ================= -->
        <mxCell id="col2header" value="2. Backend (FastAPI) — Single Source of Truth" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="90" width="320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="backendbox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="140" width="320" height="380" as="geometry" />
        </mxCell>

        <mxCell id="restapi" value="REST API&#10;/api/status  /api/room/{name}&#10;/api/usage  /api/alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="405" y="165" width="270" height="60" as="geometry" />
        </mxCell>

        <mxCell id="wsapi" value="WebSocket Endpoint&#10;/ws/dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="405" y="235" width="270" height="50" as="geometry" />
        </mxCell>

        <mxCell id="alertengine" value="Alert Engine&#10;• After-hours check (9AM-5PM)&#10;• &gt;2hr continuous-on check&#10;• Runs on every sim tick" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="405" y="295" width="270" height="70" as="geometry" />
        </mxCell>

        <mxCell id="energyacc" value="Energy Accumulator&#10;(integrates W over time -&gt; kWh)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="405" y="375" width="270" height="50" as="geometry" />
        </mxCell>

        <mxCell id="llmnote" value="LLM Layer (Claude Haiku)&#10;phrases bot replies&#10;[fallback: static templates]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontSize=10;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="405" y="435" width="270" height="55" as="geometry" />
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="devicestate" target="restapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="devicestate" target="wsapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2c" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="devicestate" target="alertengine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2d" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="devicestate" target="energyacc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= COLUMN 3: CONSUMERS ================= -->
        <mxCell id="col3header" value="3. Consumers" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="780" y="90" width="320" height="30" as="geometry" />
        </mxCell>

        <mxCell id="webui" value="Web Dashboard&#10;(single HTML/CSS/JS page)&#10;&#10;• Live Device Status Panel&#10;• Live Power Meter (total + per-room)&#10;• Active Alerts Panel&#10;• Office floor-plan (SVG, animated)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="150" width="320" height="140" as="geometry" />
        </mxCell>

        <mxCell id="discordbot" value="Discord Bot (discord.py)&#10;&#10;!status   !room &lt;name&gt;   !usage&#10;+ proactive alert posts&#10;(calls REST API, never caches)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="780" y="340" width="320" height="120" as="geometry" />
        </mxCell>

        <mxCell name="wsedge" id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.35;" edge="1" parent="1" source="wsapi" target="webui">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3label" value="WebSocket push&#10;(state changes, live)" style="edgeLabel;html=1;align=center;fontSize=10;fontColor=#666666;" vertex="1" connectable="0" parent="e3">
          <mxGeometry x="0" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="restapi" target="discordbot">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="740" y="195" />
              <mxPoint x="740" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4label" value="REST GET&#10;(on command)" style="edgeLabel;html=1;align=center;fontSize=10;fontColor=#666666;" vertex="1" connectable="0" parent="e4">
          <mxGeometry x="0" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=0.15;exitY=1;entryX=0.15;entryY=0;dashed=1;strokeColor=#b85450;" edge="1" parent="1" source="alertengine" target="discordbot">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="415" y="490" />
              <mxPoint x="795" y="490" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e5label" value="proactive push (bonus)&#10;on alert trigger" style="edgeLabel;html=1;align=center;fontSize=10;fontColor=#b85450;" vertex="1" connectable="0" parent="e5">
          <mxGeometry x="0" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ================= COLUMN 4: USER ================= -->
        <mxCell id="col4header" value="4. User" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1160" y="90" width="220" height="30" as="geometry" />
        </mxCell>

        <mxCell id="boss" value="The Boss&#10;(browser + Discord client)&#10;&#10;Sees identical live state&#10;in both interfaces" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1160" y="220" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="webui" target="boss">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;startArrow=none;exitX=1;exitY=0.5;entryX=0;entryY=0.7;" edge="1" parent="1" source="discordbot" target="boss">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7b" value="!command" style="edgeLabel;html=1;align=center;fontSize=10;fontColor=#666666;" vertex="1" connectable="0" parent="e7">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint as="offset" y="-10" /></mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legendbox" value="Legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;verticalAlign=top;fontStyle=1;fontSize=12;align=left;spacingLeft=8;spacingTop=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="leg1" value="&#8594; solid arrow = data flow" style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="&#8594; dashed red arrow = event-driven push (alert bonus)" style="text;html=1;fontSize=11;align=left;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="525" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="Backend is the single source of truth: both the Web UI and the Discord Bot&#10;read from the same REST/WebSocket API. Neither interface stores its own copy of state." style="text;html=1;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="555" width="620" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
