DISCORD_TOKEN=your_bot_token_here

# Where the backend REST API is running. Default works when the bot and backend
# run on the same machine; only change it if the backend is elsewhere.
BACKEND_URL=http://127.0.0.1:8000

# Numeric ID of the Discord channel for proactive alerts, e.g. #office-alerts
# channel. To get it: Discord Settings → Advanced → enable
# Developer Mode, then right-click the channel → Copy Channel ID. Leave blank to
# disable proactive alerts (the !status/!room/!usage commands still work).
ALERT_CHANNEL_ID=

# (Optional) LLM phrasing. Set GEMINI_API_KEY to have replies rephrased in a
# warmer, conversational tone (get a key at https://aistudio.google.com/apikey).
# Leave blank to use the built-in templates. LLM_MODEL is the model to call.
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
